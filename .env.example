APP_NAME=BaseStream
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Timezone
APP_TIMEZONE=America/Sao_Paulo

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=basestream
DB_USERNAME=postgres
DB_PASSWORD=basestream_secret

# Redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Session via Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,basestream.railway.app

# Stream Proxy
STREAM_CACHE_TTL_LIVE=300
STREAM_CACHE_TTL_VOD=3600
STREAM_DEFAULT_QUALITY=HD
STREAM_PROXY_TIMEOUT=30

# Stripe (Payments)
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Mail (Optional)
MAIL_MAILER=log
